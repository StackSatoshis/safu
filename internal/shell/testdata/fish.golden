# safu shell integration — source this from config.fish.
# Generated by `safu init`. Set SAFU_DISABLE=1 to bypass entirely.

function dd
  if test -z "$SAFU_DISABLE"; and type -q safu
    safu guard --as dd -- $argv
    if test $status -eq 10
      return 10
    end
  end
  command dd $argv
end

function git
  if test -z "$SAFU_DISABLE"; and type -q safu
    safu guard --as git -- $argv
    if test $status -eq 10
      return 10
    end
  end
  command git $argv
end

function rm
  if test -z "$SAFU_DISABLE"; and type -q safu
    safu guard --as rm -- $argv
    if test $status -eq 10
      return 10
    end
  end
  command rm $argv
end
