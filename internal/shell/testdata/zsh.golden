# safu shell integration — source this from your rc file.
# Generated by `safu init`. Set SAFU_DISABLE=1 to bypass entirely.

dd() {
  if [ -z "$SAFU_DISABLE" ] && command -v safu >/dev/null 2>&1; then
    safu guard --as dd -- "$@"
    __safu_rc=$?
    if [ "$__safu_rc" -eq 10 ]; then
      return 10
    fi
  fi
  command dd "$@"
}

git() {
  if [ -z "$SAFU_DISABLE" ] && command -v safu >/dev/null 2>&1; then
    safu guard --as git -- "$@"
    __safu_rc=$?
    if [ "$__safu_rc" -eq 10 ]; then
      return 10
    fi
  fi
  command git "$@"
}

rm() {
  if [ -z "$SAFU_DISABLE" ] && command -v safu >/dev/null 2>&1; then
    safu guard --as rm -- "$@"
    __safu_rc=$?
    if [ "$__safu_rc" -eq 10 ]; then
      return 10
    fi
  fi
  command rm "$@"
}
